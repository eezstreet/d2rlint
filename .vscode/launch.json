{
  "version": "0.2.0",
  "configurations": [
    {
      "request": "launch",
      "name": "Launch (debug)",
      "type": "node",
      "program": "${workspaceFolder}/packages/cli/main.ts",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "deno",
      "runtimeArgs": [
        "run",
        "--inspect-wait",
        "--allow-read",
        "--allow-write",
        "--allow-env"
      ],
      "attachSimplePort": 9229,
      "outputCapture": "std"
    },
    {
      "request": "attach",
      "name": "Attach to Deno",
      "type": "node",
      "port": 9229
    }
  ]
}
